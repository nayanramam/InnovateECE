[02/14 13:35:05     41s] #@ Begin verbose flow_step init_mcpu
[02/14 13:35:05     41s] @flow 2: apply {{} {
[02/14 13:35:05     41s]     # Multi host/cpu attributes
[02/14 13:35:05     41s]     #-----------------------------------------------------------------------------
[02/14 13:35:05     41s]     # The FLOWTOOL_NUM_CPUS is an environment variable which should be exported by
[02/14 13:35:05     41s]     # the specified dist script.  This connects the number of CPUs being reserved
[02/14 13:35:05     41s]     # for batch jobs with the current flow scripts.  The LSB_MAX_NUM_PROCESSORS is
[02/14 13:35:05     41s]     # a typical environment variable exported by distribution platforms and is
[02/14 13:35:05     41s]     # useful for ensuring all interactive jobs are using the reserved amount of CPUs.
[02/14 13:35:05     41s]     if {[info exists ::env(FLOWTOOL_NUM_CPUS)]} {
[02/14 13:35:05     41s]       set max_cpus $::env(FLOWTOOL_NUM_CPUS)
[02/14 13:35:05     41s]     } elseif {[info exists ::env(LSB_MAX_NUM_PROCESSORS)]} {
[02/14 13:35:05     41s]       set max_cpus $::env(LSB_MAX_NUM_PROCESSORS)
[02/14 13:35:05     41s]     } else {
[02/14 13:35:05     41s]       set max_cpus 1
[02/14 13:35:05     41s]     }
[02/14 13:35:05     41s]     switch -glob [get_db program_short_name] {
[02/14 13:35:05     41s]       default       {}
[02/14 13:35:05     41s]       joules*       -
[02/14 13:35:05     41s]       genus*        -
[02/14 13:35:05     41s]       innovus*      -
[02/14 13:35:05     41s]       tempus*       -
[02/14 13:35:05     41s]       voltus*       { set_multi_cpu_usage -verbose -local_cpu $max_cpus }
[02/14 13:35:05     41s]     }
[02/14 13:35:05     41s] if {[get_feature opt_signoff]} {
[02/14 13:35:05     41s]       if {[is_flow -inside flow:opt_signoff]} {
[02/14 13:35:05     41s]         set_multi_cpu_usage -verbose -remote_host 1
[02/14 13:35:05     41s]         set_multi_cpu_usage -verbose -cpu_per_remote_host 16
[02/14 13:35:05     41s]         set_distributed_hosts -local
[02/14 13:35:05     41s]       }
[02/14 13:35:05     41s] }
[02/14 13:35:05     41s]   }}
[02/14 13:35:05     41s] set_multi_cpu_usage -local_cpu 1
[02/14 13:35:05     41s] #@ End verbose flow_step init_mcpu
